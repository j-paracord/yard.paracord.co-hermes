#!/usr/bin/env bash
# query — thin psql wrapper for the ghost-research skill.
#
# Runs a SQL statement against $GHOST_DATABASE_URL in a read-only transaction
# with a statement timeout, so a typo can't lock anything up.
#
# Usage:
#   ./query "SELECT ..."
#   echo "SELECT ..." | ./query -

set -euo pipefail

if [[ -z "${GHOST_DATABASE_URL:-}" ]]; then
  echo "error: GHOST_DATABASE_URL is not set" >&2
  echo "hint:  add it to the agent's .env and re-sync" >&2
  exit 2
fi

if [[ $# -lt 1 ]]; then
  echo "usage: query \"SELECT ...\"   |   echo \"SELECT ...\" | query -" >&2
  exit 2
fi

if [[ "$1" == "-" ]]; then
  SQL="$(cat)"
else
  SQL="$1"
fi

PREAMBLE="SET default_transaction_read_only = on; SET statement_timeout = '30s';"

exec psql "$GHOST_DATABASE_URL" \
  --no-psqlrc \
  --pset=pager=off \
  -c "$PREAMBLE" \
  -c "$SQL"
